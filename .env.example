# Supabase project URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase SERVICE ROLE key (Project Settings -> API -> service_role secret).
# Server-only. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared admin PIN. Required for every add / edit / archive / +1 / -1 action.
INVENTORY_ADMIN_PIN=1234

# Public base URL of the deployed site, used to build absolute QR code links.
# Local: http://localhost:3000   Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
